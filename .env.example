# Hermes-mini 配置示例
# 复制为 .env 并填入你的实际 Key

# ====================
# MiniMax EAS（默认）
# ====================
# Base URL（一般不需要改）
HERMES_MINIMAX_BASE_URL=http://1505824313958960.cn-hangzhou.pai-eas.aliyuncs.com/api/predict/minimax_m2/v1/chat/completions
# API Key（必填）
HERMES_MINIMAX_API_KEY=你的MiniMax_API_Key

# ====================
# GLM（智谱，可选）
# ====================
GLM_API_KEY=你的GLM_API_Key

# ====================
# Qwen（阿里通义，可选）
# ====================
QWEN_API_KEY=你的QWEN_API_Key

# ====================
# OpenAI（可选）
# ====================
OPENAI_API_KEY=你的OpenAI_API_Key
